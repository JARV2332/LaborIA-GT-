# ──────────────────────────────────────────────────────────────────────────────
# LaborIA GT — Variables de entorno
# Copia este archivo como `.env.local` y rellena tus valores reales.
# NUNCA subas `.env.local` a GitHub (ya está en .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# API Key de Groq (gratis en console.groq.com)
GROQ_API_KEY=gsk_TU_KEY_AQUI

# Modelo de visión para análisis de documentos
# Groq vision: meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Modelo de chat para el consultor legal
# Groq chat: llama-3.3-70b-versatile (más potente) o llama-3.1-8b-instant (más rápido)
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
